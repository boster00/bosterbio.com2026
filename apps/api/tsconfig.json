{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2021",
    "module": "Node16",
    "moduleResolution": "Node16",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "outDir": "./.medusa/server",
    "rootDir": ".",
    "jsx": "react-jsx",
    "paths": {
      "@bosterbio/types": ["../../packages/types/src"]
    }
  },
  "ts-node": {
    "swc": true
  },
  "include": ["src", "medusa-config.ts", ".medusa/types/*"],
  "exclude": ["node_modules", ".medusa/server", ".medusa/admin"]
}
