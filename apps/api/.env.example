# Database — PlanetScale (PostgreSQL-compatible connection string)
DATABASE_URL=postgresql://user:password@host/bosterbio

# Redis (required for Medusa job queues)
REDIS_URL=redis://localhost:6379

# Auth secrets — replace with strong random values in production
JWT_SECRET=change_me_in_production
COOKIE_SECRET=change_me_in_production

# CORS — comma-separated origins
STORE_CORS=http://localhost:3000,https://bosterbio.com
ADMIN_CORS=http://localhost:7001,https://admin.bosterbio.com
AUTH_CORS=http://localhost:3000,https://bosterbio.com

# Payment provider — currently Stripe (swappable, see src/modules/payment)
# Replace PAYMENT_PROVIDER value to switch providers without touching storefront code
PAYMENT_PROVIDER=stripe
STRIPE_API_KEY=sk_test_placeholder

# Algolia
ALGOLIA_APP_ID=
ALGOLIA_ADMIN_API_KEY=

# Admin URL
MEDUSA_ADMIN_BACKEND_URL=http://localhost:9000
