# Medusa backend (catalog + commerce — local PostgreSQL). Point at your running Medusa HTTP URL.
NEXT_PUBLIC_MEDUSA_BACKEND_URL=[REDACTED]
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
# After Postgres + migrations: from apps/api run `pnpm seed:catalog` to load five featured antibodies.

# Algolia search
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# Analytics / etc.
NEXT_PUBLIC_SITE_URL=[REDACTED]

# Supabase Storage (Puppeteer upload scripts load this file). Typo variable name is supported in code.
# SUPABASE_URL=
# SUPABASE_SECRETE_KEY=
