# Medusa backend
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
# Medusa v2 store pricing context (Admin → Regions, or `region` table)
NEXT_PUBLIC_MEDUSA_REGION_ID=

# Algolia search
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# Analytics / etc.
NEXT_PUBLIC_SITE_URL=https://bosterbio.com

# BosterBio catalog (Supabase). Prefer BOSTERBIO_* in CI / Cloud Agents when set.
BOSTERBIO_SUPABASE_URL=
BOSTERBIO_SUPABASE_KEY=
BOSTERBIO_SUPABASE_ANON_KEY=

# Local fallback when not using BOSTERBIO_* names:
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SECRETE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
