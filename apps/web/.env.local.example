# Medusa backend
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=
# Medusa v2 store pricing context (Admin → Regions, or `region` table)
NEXT_PUBLIC_MEDUSA_REGION_ID=

# BosterBio storefront catalog (Supabase — products, CMS, publications).
# Prefer when GuildOS uses NEXT_PUBLIC_SUPABASE_URL only for quest bookkeeping.
BOSTERBIO_SUPABASE_URL=
BOSTERBIO_SUPABASE_KEY=
# Optional anon for browser reads (service role is used server-side)
NEXT_PUBLIC_BOSTERBIO_SUPABASE_ANON_KEY=

# Legacy single-project layout (supported if BOSTERBIO_* are unset)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRETE_KEY=

# Algolia search
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# Analytics / etc.
NEXT_PUBLIC_SITE_URL=https://bosterbio.com
