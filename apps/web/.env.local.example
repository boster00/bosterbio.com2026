# Medusa backend
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# Figma API — used to pull design tokens and assets from the Boster Design Master File
# Token is available in .env.local on the dev machine. Generate at https://www.figma.com/developers/api#access-tokens
FIGMA_ACCESS_TOKEN=

# Algolia search
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# Analytics / etc.
NEXT_PUBLIC_SITE_URL=https://bosterbio.com
