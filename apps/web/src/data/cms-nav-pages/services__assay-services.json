column content-section\">\n    <div class=\"container\">\n        <div class=\"row\">\n            <div class=\"col-md-4 p-0\">\n                <div style=\"background-image: url('/media/images/homepage/homepage-fusion-medical-animation.jpg')\"\n                    class=\"h-100 background-cover\"></div>\n            </div>\n            <div class=\"col-md-8 p-0\">\n                <div class=\"bg-lightgrey p-5\">\n                    <h2 class=\"font-large text-orange mb-2 topic-heading\">\n                        AAV Packaging Service\n                    </h2>\n                    <p class=\"font-medium text-grey mb-4\">\n                        Need custom-produced AAV?\n                    </p>\n                    <p>\n                        Our innovative <a href=\"https://SITE_ORIGIN_PLACEHOLDER/services/aav-packaging-service\" style=\"color:#EA8D28\">AAV production service</a> is <span class=\"font-weight-bold\">10-100 times more efficient</span> \n                        than traditional methods and produces up to 1E+15GC/mL AAV in one single \n                        production. Get a free consultation today and improve your AAV vectors' infection \n                        efficiency while saving budget.\n                    </p>\n                    <a class=\"btn-orange mr-4\"\n                        href=\"https://SITE_ORIGIN_PLACEHOLDER/services/aav-packaging-service\">\n                        See AAV Packaging Details\n                    </a>\n                </div>\n            </div>\n\n        </div>\n    </div>\n</section>\n<section class=\"mb-6 double-column content-section\">\n    <div class=\"container\">\n        <div class=\"row\">\n            <div class=\"col-md-4 p-0\">\n                <div style=\"background-image: url('/media/images/homepage/homepage-biomarkers-and-fluorophores.png')\"\n                    class=\"h-100 background-cover\"></div>\n            </div>\n            <div class=\"col-md-8 p-0\">\n                <div cl