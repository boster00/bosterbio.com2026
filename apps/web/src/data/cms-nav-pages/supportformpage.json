{"page_id":"803","title":"supportFormPage","identifier":"supportformpage","content_heading":"","update_time":"2025-08-28 06:57:16","content":"<section>\n    <!-- Custom CSS -->\n    <link rel=\"stylesheet\" href=\"/css/supportForm.css\">\n<div class=\"container mt-4\">\n        <div class=\"form-container\">\n            <!-- Header -->\n            <div class=\"form-header\">\n                <h2>Boster Bio Technical Support Form</h2>\n            </div>\n            \n            <!-- Instructions -->\n            <div class=\"instructions\">\n                <p><strong>Dear Valued Customer,</strong></p>\n                <p>Boster Bio's guarantee promises that our products perform as indicated on the datasheet. Please help fill out this form so our technical team can help troubleshoot your experiment. If we find out that the product does not perform as advertised, we will issue you a full refund or a replacement lot, to your preference.</p>\n                <!-- Removed Chinese contact info and replaced with English -->\n                <p>Contact us: support@bosterbio.com</p>\n            </div>\n\n            <!-- Form -->\n            <form id=\"supportForm\" novalidate>\n                <!-- Name Fields -->\n                <div class=\"row\">\n                    <div class=\"col-md-6\">\n                        <div class=\"form-group\">\n                            <label for=\"firstName\">First Name <span class=\"required\">*</span></label>\n                            <input type=\"text\" class=\"form-control\" id=\"firstName\" name=\"firstName\" placeholder=\"Your first name\" required>\n                        </div>\n                    </div>\n                    <div class=\"col-md-6\">\n                        <div class=\"form-group\">\n                            <label for=\"lastName\">Last Name <span class=\"required\">*</span></label>\n                            <input type=\"text\" class=\"form-control\" id=\"lastName\" name=\"lastName\" placeholder=\"Your last name\" required>\n                        </div>\n                    </div>\n                </div>\n\n                <!-- Email Field -->\n                <div class=\"form-group\">\n                    <!-- Changed label from Chinese to English -->\n                    <label for=\"email\">Email Address <span class=\"required\">*</span></label>\n                    <!-- Changed placeholder from Chinese to English -->\n                    <input type=\"email\" class=\"form-control\" id=\"email\" name=\"email\" placeholder=\"Your email address\" required>\n                </div>\n\n                <!-- SKU Field -->\n                <div class=\"form-group\">\n                    <label for=\"sku\">What is the SKU of the product? <span class=\"required\">*</span></label>\n                    <!-- Changed placeholder from Chinese to English -->\n                    <input type=\"text\" class=\"form-control\" id=\"sku\" name=\"sku\" placeholder=\"Your answer\" required>\n                </div>\n\n                <!-- Lot Number Field -->\n                <div class=\"form-group\">\n                    <label for=\"lotNumber\">What is the lot # of the product? You can find this info on the label of the product. <span class=\"required\">*</span></label>\n                    <!-- Changed placeholder from Chinese to English -->\n                    <input type=\"text\" class=\"form-control\" id=\"lotNumber\" name=\"lotNumber\" placeholder=\"Your answer\" required>\n                </div>\n\n                <!-- Order Reference Field -->\n                <div class=\"form-group\">\n                    <label for=\"orderRef\">Can you give us any order reference numbers or time of purchase to help us locate your order?</label>\n                    <!-- Changed placeholder from Chinese to English -->\n                    <input type=\"text\" class=\"form-control\" id=\"orderRef\" name=\"orderRef\" placeholder=\"Your answer\">\n                </div>\n\n                <!-- File Upload Field -->\n                <div class=\"form-group\">\n                    <label for=\"fileUpload\">Upload your experiment results data <span class=\"required\">*</span></label>\n                    <div class=\"file-upload-container\">\n                        <input type=\"file\" class=\"form-control-file\" id=\"fileUpload\" name=\"fileUpload\" accept=\".pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.jpg,.jpeg,.png,.gif,.zip\">\n                        <!-- Changed help text from Chinese to English -->\n                        <small class=\"form-text text-muted\">Supports PDF, documents, images, presentations, spreadsheets, or ZIP files. Maximum file size: 10MB. Only 1 file allowed.</small>\n                        <!-- Changed button text from Chinese to English -->\n                        <button type=\"button\" class=\"btn btn-outline-secondary btn-sm mt-2\" id=\"addFileBtn\">Choose File</button>\n                    </div>\n                </div>\n\n                <!-- Protocol Field -->\n                <div class=\"form-group\">\n                    <label for=\"protocol\">What is the protocol you used? Include sample details, sample preparations, and experiment steps. <span class=\"required\">*</span></label>\n                    <!-- Changed placeholder from Chinese to English -->\n                    <textarea class=\"form-control\" id=\"protocol\" name=\"protocol\" rows=\"5\" placeholder=\"Your answer\" required></textarea>\n                </div>\n\n                <!-- Preference Radio Buttons -->\n                <div class=\"form-group\">\n                    <label>If the product proves to not work, what would you prefer? <span class=\"required\">*</span></label>\n                    <div class=\"form-check\">\n                        <input class=\"form-check-input\" type=\"radio\" name=\"preference\" id=\"refund\" value=\"refund\" required>\n                        <label class=\"form-check-label\" for=\"refund\">\n                            Refund\n                        </label>\n                    </div>\n                    <div class=\"form-check\">\n                        <input class=\"form-check-input\" type=\"radio\" name=\"preference\" id=\"replacement\" value=\"replacement\" required>\n                        <label class=\"form-check-label\" for=\"replacement\">\n                            Replacement with a new lot\n                        </label>\n                    </div>\n                </div>\n\n                <!-- Bottom Notice -->\n                <div class=\"bottom-notice\">\n                    <!-- Changed notice from Chinese to English -->\n                    <p>Thank you for trusting our products. We will provide you with a satisfactory solution as soon as possible.</p>\n                </div>\n\n                <!-- Form Actions -->\n                <div class=\"form-actions\">\n                    <!-- Changed button text from Chinese to English -->\n                    <button type=\"submit\" class=\"btn btn-primary submit-btn\">Submit</button>\n                    <!-- Changed link text from Chinese to English -->\n                    <a href=\"#\" id=\"clearForm\" class=\"clear-link\">Clear Form</a>\n                </div>\n            </form>\n        </div>\n    </div>\n    <!-- jQuery -->\n    \n    <!-- Custom JavaScript -->\n    \n</section>"}