{"page_id":"782","title":"Search antibody by Research Fields","identifier":"antibody-categories","content_heading":"","update_time":"2026-04-08 03:31:08","content":"            <section class=\"mb-4 text-center hero-section\" style=\"background-image: url(/media/images/design-guide/background-celltype.jpg)\">\n  <div class=\"dark-overlap\">\n    <h1 class=\"font-large font-weight-bold mb-4\">\n      <font face=\"Josefin Sans, tahoma, sans-serif\">\n        <span style=\"font-size: 50px; text-transform: uppercase;\">Antibodies by Research Field</span>\n      </font>\n    </h1>\n    <p class=\"font-large mb-4\">\n      Browse antibodies through 10 major research fields, then refine by disease, cell type, additional topics, or rare species.\n    </p>\n    <div class=\"d-flex justify-content-center\">\n      <a class=\"btn-outline-white\" href=\"#major-research-fields\">Browse Major Research Fields</a>\n    </div>\n  </div>\n</section>\n<section class=\"mb-6 single-column content-section\" id=\"major-research-fields\">\n  <div class=\"container\">\n    <div class=\"row\">\n      <div class=\"col-12\">\n        <h2 class=\"font-large text-orange mb-2 text-capitalize\">10 Major Research Fields</h2>\n        <p class=\"font-medium text-grey mb-5\">\n          Start with Boster’s primary research field landing pages, then narrow your search through related disease categories, cell types, and specialized research topics below.\n        </p>\n      </div>\n      <div class=\"col-12\">\n        <div class=\"row\">\n          <div class=\"col-12 col-lg-6 mb-3\">\n            <a href=\"https://SITE_ORIGIN_PLACEHOLDER/research-area/immunology-antibodies\" class=\"text-decoration-none d-block h-100\">\n              <div class=\"p-4 h-100\" style=\"background:#f7f7f7; border-left:4px solid #f39a27;\">\n                <h3 class=\"font-large text-orange mb-2\">Immunology Antibodies</h3>\n                <p class=\"mb-2 text-grey\">Cytokines, immune markers, inflammation, immune response.</p>\n                <p class=\"mb-0 text-orange font-weight-bold\">Explore →</p>\n              </div>\n            </a>\n          </div>\n          <div class=\"col-12 col-lg-6 mb-3\">\n            <a href=\"https://SITE_ORIGIN_PLACEHOLDER/research-area/neuroscience-antibodies\" class=\"text-decoration-none d-block h-100\">\n              <div class=\"p-4 h-100\" style=\"background:#f7f7f7; border-left:4px solid #f39a27;\">\n                <h3 class=\"font-large text-orange mb-2\">Neuroscience Antibodies</h3>\n                <p class=\"mb-2 text-grey\">Neural markers, glia, neurodegeneration, brain pathways.</p>\n                <p class=\"mb-0 text-orange font-weight-bold\">Explore →</p>\n              </div>\n            </a>\n          </div>\n          <div class=\"col-12 col-lg-6 mb-3\">\n            <a href=\"https://SITE_ORIGIN_PLACEHOLDER/research-area/cancer-antibodies\" class=\"text-decoration-none d-block h-100\">\n              <div class=\"p-4 h-100\" style=\"background:#f7f7f7; border-left:4px solid #f39a27;\">\n                <h3 class=\"font-large text-orange mb-2\">Cancer Antibodies</h3>\n                <p class=\"mb-2 text-grey\">Tumor biomarkers, TME, oncology pathways, disease relevance.</p>\n                <p class=\"mb-0 text-orange font-weight-bold\">Explore →</p>\n              </div>\n            </a>\n          </div>\n          <div class=\"col-12 col-lg-6 mb-3\">\n            <a href=\"https://SITE_ORIGIN_PLACEHOLDER/research-area/epigenetics-antiboies\" class=\"text-decoration-none d-block h-100\">\n              <div class=\"p-4 h-100\" style=\"background:#f7f7f7; border-left:4px solid #f39a27;\">\n                <h3 class=\"font-large text-orange mb-2\">Epigenetics Antibodies</h3>\n                <p class=\"mb-2 text-grey\">Histone marks, chromatin, transcriptional control, regulation.</p>\n                <p class=\"mb-0 text-orange font-weight-bold\">Explore →</p>\n              </div>\n            </a>\n          </div>\n          <div class=\"col-12 col-lg-6 mb-3\">\n            <a href=\"https://SITE_ORIGIN_PLACEHOLDER/research-area/developmental-biology-antibodies\" class=\"text-decoration-none d-block h-100\">\n              <div class=\"p-4 h-100\" style=\"background:#f7f7f7; border-left:4px solid #f39a27;\">\n                <h3 class=\"font-large text-orange mb-2\">Developmental Biology Antibodies</h3>\n                <p class=\"mb-2 text-grey\">Embryogenesis, lineage markers, morphogenesis, development.</p>\n                <p class=\"mb-0 text-orange font-weight-bold\">Explore →</p>\n              </div>\n            </a>\n          </div>\n          <div class=\"col-12 col-lg-6 mb-3\">\n            <a href=\"https://SITE_ORIGIN_PLACEHOLDER/research-area/infectious-disease-antibodies\" class=\"text-decoration-none d-block h-100\">\n              <div class=\"p-4 h-100\" style=\"background:#f7f7f7; border-left:4px solid #f39a27;\">\n                <h3 class=\"font-large text-orange mb-2\">Infectious Disease Antibodies</h3>\n                <p class=\"mb-2 text-grey\">Host response, infection biology, inflammation, defense pathways.</p>\n                <p class=\"mb-0 text-orange font-weight-bold\">Explore →</p>\n              </div>\n            </a>\n          </div>\n          <div class=\"col-12 col-lg-6 mb-3\">\n            <a href=\"https://SITE_ORIGIN_PLACEHOLDER/research-area/stem-cell-and-regenerative-biology-antibodies\" class=\"text-decoration-none d-block h-100\">\n              <div class=\"p-4 h-100\" style=\"background:#f7f7f7; border-left:4px solid #f39a27;\">\n                <h3 class=\"font-large text-orange mb-2\">Stem Cell and Regenerative Biology Antibodies</h3>\n                <p class=\"mb-2 text-grey\">Stemness, differentiation, regeneration, tissue repair.</p>\n                <p class=\"mb-0 text-orange font-weight-bold\">Explore →</p>\n              </div>\n            </a>\n          </div>\n          <div class=\"col-12 col-lg-6 mb-3\">\n            <a href=\"https://SITE_ORIGIN_PLACEHOLDER/research-area/cardiovascular-disease-antibodies\" class=\"text-decoration-none d-block h-100\">\n              <div class=\"p-4 h-100\" style=\"background:#f7f7f7; border-left:4px solid #f39a27;\">\n                <h3 class=\"font-large text-orange mb-2\">Cardiovascular Disease Antibodies</h3>\n                <p class=\"mb-2 text-grey\">Cardiac biology, vascular dysfunction, remodeling, endothelium.</p>\n                <p class=\"mb-0 text-orange font-weight-bold\">Explore →</p>\n              </div>\n            </a>\n          </div>\n          <div class=\"col-12 col-lg-6 mb-3\">\n            <a href=\"https://SITE_ORIGIN_PLACEHOLDER/research-area/fibrosis-antibody\" class=\"text-decoration-none d-block h-100\">\n              <div class=\"p-4 h-100\" style=\"background:#f7f7f7; border-left:4px solid #f39a27;\">\n                <h3 class=\"font-large text-orange mb-2\">Fibrosis Antibodies</h3>\n                <p class=\"mb-2 text-grey\">Fibroblasts, ECM remodeling, profibrotic signaling, fibrosis.</p>\n                <p class=\"mb-0 text-orange font-weight-bold\">Explore →</p>\n              </div>\n            </a>\n          </div>\n          <div class=\"col-12 col-lg-6 mb-3\">\n            <a href=\"https://SITE_ORIGIN_PLACEHOLDER/research-area/metabolism-antibodies\" class=\"text-decoration-none d-block h-100\">\n              <div class=\"p-4 h-100\" style=\"background:#f7f7f7; border-left:4px solid #f39a27;\">\n                <h3 class=\"font-large text-orange mb-2\">Metabolism Antibodies</h3>\n                <p class=\"mb-2 text-grey\">Liver, adipose biology, insulin signaling, energy regulation.</p>\n                <p class=\"mb-0 text-orange font-weight-bold\">Explore →</p>\n              </div>\n            </a>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n<section class=\"mb-6 single-column content-section\">\n  <div class=\"container\">\n    <div cl